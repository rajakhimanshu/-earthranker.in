rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Leaderboard rules
    match /leaderboard/{entryId} {
      
      // Anyone can read the global leaderboard
      allow read: if true;
      
      // Allow creation of new entries with basic validation
      // We prevent updates and deletes to ensure scores can't be tampered with after submission
      allow create: if 
        request.resource.data.score is number &&
        request.resource.data.score >= 0 &&
        request.resource.data.score <= 100 &&
        request.resource.data.displayName is string &&
        request.resource.data.displayName.size() > 0 &&
        request.resource.data.displayName.size() <= 25 &&
        request.resource.data.timestamp == request.time;

      // No one can update or delete entries (including the author, as we don't have auth yet)
      allow update, delete: if false;
    }
    
    // Default deny for all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
